    "RefreshIntervalInSeconds":  120
  },
  // Configuration de la base de données
  "ConnectionStrings": {
    "Default": "Server=192.168.1.126;Database=aquamancy;User=aquamancy;Password=admin;"
  },
  // Gestion de l'intégration avec Discord
  "Discord": {
    // Activer/Désactiver les notifications Discord
    "NotificationEnabled": true,
    // URL du webhook Discord pour les notifications (peut être généré depuis les paramètres du serveur Discord)
    "WebhookUrl": "https://discord.com/api/webhooks/1441734616317825157/Qi0J1wCbGK5i-FtJUGqfnTHWkJzJcLIV16neS4qRQ9fEb0I5rK2wpZmaSSU_Ae-I91Yv",
