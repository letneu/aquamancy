{
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Chart": {
    // De combien d'heure en arrière les données du graphique démarrent-elles
    "DisplayLastHours": 24,
    // Facteur affectant la taille de la police dans le graphique
    "FontSizeMultiplier": 2,
